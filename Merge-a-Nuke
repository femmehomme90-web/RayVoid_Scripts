local function parseShortNumber(text)
    if not text then return 0 end
    local num, suffix = text:match("([%d%.]+)%s*([A-Za-z]*)")
    if not num then return 0 end
    num = tonumber(num) or 0
    suffix = suffix:upper()
    local mult = {
        K = 1e3, M = 1e6, B = 1e9, T = 1e12,
        QA = 1e15, QI = 1e18, SX = 1e21, SP = 1e24,
    }
    return num * (mult[suffix] or 1)
end

local function getCash()
    local ok, label = pcall(function()
        return player.PlayerGui:WaitForChild("CashVFX"):WaitForChild("CashText")
    end)
    if not ok or not label then return 0 end
    local text = label.Text:gsub("Cash: ", "")
    return parseShortNumber(text)
end

local function getUpgradePrice(upgradeKey)
    local ok, label = pcall(function()
        return player.PlayerGui.ScreenGui.Frames.UpgradesFrame.Frame[upgradeKey].Upgrade.TextLabel
    end)
    if not ok or not label then return math.huge end
    return parseShortNumber(label.Text)
end

local upgradeThreads = {}

local upgrades = {
    { name = "Auto Upgrade Tier",     remote = "TIER",     key = "Tier"     },
    { name = "Auto Upgrade Max",      remote = "MAX",      key = "Max"      },
    { name = "Auto Upgrade LockBase", remote = "LOCKBASE", key = "LockBase" },
}

for _, upg in ipairs(upgrades) do
    local flag = upg.remote
    UpgradeTab:CreateToggle({
        Name = upg.name,
        CurrentValue = false,
        Flag = flag,
        Callback = function(val)
            if val then
                upgradeThreads[flag] = true
                task.spawn(function()
                    while upgradeThreads[flag] do
                        task.wait(1)
                        local cash  = getCash()
                        local price = getUpgradePrice(upg.key)
                        if cash >= price then
                            PurchaseUpgrade:FireServer(upg.remote)
                        end
                    end
                end)
                Ui:Notify({ Title = upg.name, Content = "Enabled",  Duration = 2, Image = 4483362458 })
            else
                upgradeThreads[flag] = nil
                Ui:Notify({ Title = upg.name, Content = "Disabled", Duration = 2, Image = 4483362458 })
            end
        end,
    })
end

